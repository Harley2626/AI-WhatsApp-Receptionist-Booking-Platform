# ─── App ─────────────────────────────────────────────────────────────────
# Public URL of this deployment (no trailing slash). Used for auth redirects,
# WhatsApp/PayFast webhook URLs, and Google OAuth callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase — Project Settings → API (https://supabase.com/dashboard) ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── OpenAI — https://platform.openai.com/api-keys ─────────────────────────
OPENAI_API_KEY=
# Optional override; defaults to gpt-5.5
OPENAI_MODEL=gpt-5.5

# ─── Meta WhatsApp Cloud API — https://developers.facebook.com/apps ────────
# Shared secret you choose yourself and enter in the Meta webhook config.
# Per-business phone_number_id + access_token are entered during onboarding
# and stored in Supabase (integrations / integration_secrets tables).
WHATSAPP_VERIFY_TOKEN=

# ─── Google Calendar OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# ─── PayFast — https://www.payfast.co.za ───────────────────────────────────
# Per-business merchant_id/merchant_key/passphrase are entered during
# onboarding and stored in Supabase. This flag just controls sandbox vs live.
PAYFAST_SANDBOX=true

# ─── Cron — protects /api/cron/reminders from public calls ─────────────────
# Vercel Cron sends this as `Authorization: Bearer <value>`.
CRON_SECRET=
